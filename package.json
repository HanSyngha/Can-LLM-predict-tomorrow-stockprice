{
  "name": "stock-self-evolving",
  "version": "0.1.0",
  "description": "LLM self-reflection stock prediction system",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --outdir=dist/server --packages=external && cp -r src/server/db/migrations dist/server/",
    "build:client": "vite build",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.0.4",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "chart.js": "^4.4.7",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "ws": "^8.18.0",
    "yahoo-finance2": "^2.14.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
