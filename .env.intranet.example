# ============================================================
# .env.intranet.example — 사내망 배포용 환경변수 템플릿
# 복사 후 .env로 사용: cp .env.intranet.example .env
# ============================================================

# === 프록시 설정 (사내망 → 외부 인터넷) ===
# Yahoo Finance, KIS API 등 외부 API 접근에 필요
HTTP_PROXY=http://proxy.your-company.com:8080
HTTPS_PROXY=http://proxy.your-company.com:8080

# 프록시 우회 대상 (사내 LLM 서버, localhost 등)
# 사내 LLM 주소를 여기에 추가해야 LLM 호출이 프록시를 타지 않음
NO_PROXY=localhost,127.0.0.1,.your-company.com,사내LLM주소

# === 서버 포트 ===
APP_PORT=4001
